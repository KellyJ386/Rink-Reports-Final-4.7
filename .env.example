# Supabase project — values for gzzzxkvbhusvyoxlwcpd.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://gzzzxkvbhusvyoxlwcpd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of the deployed app. Used in invite emails and links.
NEXT_PUBLIC_APP_URL=https://app.rinkreports.com

# Used only by local Supabase CLI for db push / db test
SUPABASE_DB_PASSWORD=

# Stripe — required for billing. Without these, Agent 6's Manage Billing button
# stays disabled and the subscription banner won't be fully interactive.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_SINGLE_FACILITY_MONTHLY=price_...
STRIPE_PRICE_ID_SINGLE_FACILITY_ANNUAL=price_...

# Resend (transactional email). If unset, publish_notification still records
# in-app / Realtime notifications but silently skips email delivery.
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS="Rink Reports <onboarding@resend.dev>"

# Sentry (error tracking). Missing DSNs disable capture silently.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# PostHog (product analytics). Optional — omit both to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Upstash QStash (scheduled jobs). Required in production; dev mode skips
# signature verification with a console warning if unset.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Upstash Redis (rate limiter). Required in production; dev + CI fall back to
# the in-memory token bucket when these are absent. Grab the REST URL + token
# from the Upstash console (not the redis:// string).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
