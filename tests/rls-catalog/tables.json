{
  "_readme": "Input catalog for scripts/generate-rls-catalog.mjs. Every tenant-scoped table in the product must appear here. Future agents: when you add a new tenant-scoped table, add a row here and run `npm run rls:generate`. The generator emits supabase/tests/20_rls_catalog.test.sql which is committed alongside your migration.",
  "_conventions": {
    "facility_column": "Name of the column whose value must equal current_facility_id() for visibility. Most tables use 'facility_id'. Set to null for global tables that shouldn't be in this catalog at all.",
    "parent_table": "If a table doesn't have its own facility_id column but inherits scope through a FK (e.g. shift_assignments → shifts), name the parent here. The generator emits a SELECT attack via the FK join rather than a direct equality check.",
    "parent_fk_column": "The FK column on this table that points to parent_table.",
    "skip_reason": "Set when a table is intentionally not covered (e.g. global catalog tables). Documented in RLS_TEST_CATALOG.md."
  },
  "tables": [
    { "name": "facilities", "facility_column": "id" },
    { "name": "users", "facility_column": "facility_id" },
    { "name": "roles", "facility_column": "facility_id" },
    { "name": "user_roles", "parent_table": "roles", "parent_fk_column": "role_id" },
    { "name": "facility_modules", "facility_column": "facility_id" },
